# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic API
# Get from: https://console.anthropic.com/
# Rotate every 90 days.
ANTHROPIC_API_KEY=

# AI Knowledgebase
# Absolute path to your local AI-Knowledgebase repo.
# Example: /Users/yourname/AI-Knowledgebase/
KB_PATH=

# Database
# Path to SQLite file. Relative to backend/ or absolute.
# Example: ./zenkai.db
DB_PATH=./zenkai.db

# PixelLab (pixel art asset generation)
# Get from: https://pixellab.ai
# Rotate every 90 days.
PIXELLAB_API_KEY=

# CORS — allowed origins for the FastAPI backend
# Local dev: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
